{
  "feature.gateway.title": {
    "message": "网关与路由"
  },
  "feature.gateway.description": {
    "message": "兼容 OpenAI 的 API 端点 (/v1/*)，可将请求路由到本地运行时（vLLM、llama.cpp、Ollama、TGI）和远程提供商（OpenAI、Azure 等）。基于别名的模型解析、SSE 流式传输与 TTFT 提取，以及自动重试。"
  },
  "feature.security.title": {
    "message": "安全与隐私"
  },
  "feature.security.description": {
    "message": "完整的 RBAC 与 JWT 认证、OAuth / SSO / OIDC、Redis 速率限制、并发租约和 Fernet 加密的数据库密钥。基于 Presidio 的 PII 检测，支持租户级策略、可配置的实体类型和故障安全模式。"
  },
  "feature.observability.title": {
    "message": "可观测性"
  },
  "feature.observability.description": {
    "message": "Langfuse 追踪与隐私模式、Loki + Alloy 集中式日志、OpenTelemetry + Jaeger 分布式追踪，以及嵌入 Grafana 面板的仪表板。每个网关请求和管理操作均有审计日志。"
  },
  "feature.rag.title": {
    "message": "RAG 管道"
  },
  "feature.rag.description": {
    "message": "多租户检索，支持向量、关键词和混合搜索。虚拟容器树，具有草稿/发布工作流、MinIO 预签名上传、收集器插件和通过 Taskiq + RabbitMQ 的异步处理。"
  },
  "feature.ops.title": {
    "message": "运维控制台"
  },
  "feature.ops.description": {
    "message": "完整的容器生命周期管理、带 SSE 进度的镜像拉取、Compose 栈部署/回滚（含版本和审计跟踪）。多厂商 GPU 自动检测（NVIDIA、AMD、Intel、Apple Metal）。"
  },
  "feature.cli.title": {
    "message": "CLI 与自动化"
  },
  "feature.cli.description": {
    "message": "llmport up/down/status/logs，交互式生产安装器（GPU 自动检测和 TUI），dev init 完整开发者工作区设置，doctor 健康检查和 .env 生成。"
  },
  "hero.description": {
    "message": "路由、保护和观测本地 LLM 运行时与远程提供商之间的流量 ── 为团队提供端到端管理 LLM 服务的统一平台。"
  },
  "hero.getStarted": {
    "message": "快速开始"
  },
  "section.features.title": {
    "message": "功能概览"
  },
  "section.why.title": {
    "message": "为什么选择 llm.port"
  },
  "section.why.bold": {
    "message": "默认主权 AI"
  },
  "section.why.text": {
    "message": "需要时将数据保留在本地，允许时使用远程提供商，无需更改应用或失去治理和可观测性。一个平台取代了代理、仪表板和脚本的拼凑组合。"
  },
  "section.screenshots.title": {
    "message": "界面截图"
  },
  "section.enterprise.bold": {
    "message": "企业版功能可用"
  },
  "section.enterprise.text": {
    "message": "适用于需要 SSO、高级 PII 令牌化和治理的团队。"
  },
